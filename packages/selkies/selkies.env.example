# Copy to /etc/selkies.env. Keep mode 0600 if TURN credentials are added.
# LightOS normally generates SELKIES_TURN_* values during setup.
SELKIES_UI_TITLE=Agent
SELKIES_UI_SHOW_LOGO=false
SELKIES_UI_SIDEBAR_SHOW_APPS=false
SELKIES_USE_CSS_SCALING=true
SELKIES_IS_MANUAL_RESOLUTION_MODE=true
SELKIES_MANUAL_WIDTH=1920
SELKIES_MANUAL_HEIGHT=1080
SELKIES_WEB_ROOT=/usr/share/selkies/web
SELKIES_ENABLE_BASIC_AUTH=false
SELKIES_PORT=9091
# Optional, generated externally; never commit real values:
# SELKIES_TURN_HOST=
# SELKIES_TURN_PORT=3478
# SELKIES_TURN_PROTOCOL=udp
# SELKIES_TURN_USERNAME=
# SELKIES_TURN_PASSWORD=
