[Unit]
Description=Xvfb Virtual Display for Selkies
After=network.target
[Service]
SupplementaryGroups=render video
Type=simple
Environment=DISPLAY=:1
ExecStart=/usr/bin/Xvfb :1 -screen 0 1920x1080x24 -ac -nolisten tcp -dpi 120 +extension GLX +extension RANDR +extension RENDER
Restart=always
RestartSec=3
[Install]
WantedBy=graphical.target
